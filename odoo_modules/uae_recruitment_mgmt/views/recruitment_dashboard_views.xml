<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dashboard Form View -->
    <record id="view_recruitment_dashboard_form" model="ir.ui.view">
        <field name="name">recruitment.dashboard.form</field>
        <field name="model">recruitment.dashboard</field>
        <field name="arch" type="xml">
            <form string="Recruitment Dashboard" create="false" edit="false" delete="false">
                <sheet>
                    <div class="oe_title">
                        <h1>📊 Recruitment Dashboard</h1>
                        <p class="text-muted">Real-time recruitment metrics and analytics</p>
                    </div>

                    <!-- Key Metrics Section -->
                    <group string="Key Performance Indicators" col="4">
                        <field name="active_jobs" widget="statinfo" string="Active Jobs"/>
                        <field name="total_candidates" widget="statinfo" string="Total Candidates"/>
                        <field name="placements_month" widget="statinfo" string="Placements (Month)"/>
                        <field name="total_revenue" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                    </group>

                    <group string="Secondary Metrics" col="4">
                        <field name="visa_in_progress" widget="statinfo" string="Visa In Progress"/>
                        <field name="visa_completed" widget="statinfo" string="Visa Completed"/>
                        <field name="active_clients" widget="statinfo" string="Active Clients"/>
                        <field name="total_clients" widget="statinfo" string="Total Clients"/>
                    </group>

                    <notebook>
                        <!-- Job Orders Tab -->
                        <page string="📋 Job Orders">
                            <group string="Job Order Statistics" col="4">
                                <field name="job_total"/>
                                <field name="job_active" decoration-info="job_active > 0"/>
                                <field name="job_posted" decoration-warning="job_posted > 0"/>
                                <field name="job_filled" decoration-success="job_filled > 0"/>
                                <field name="job_closed"/>
                                <field name="avg_time_to_fill" string="Avg Days to Fill" widget="float"/>
                            </group>
                            
                            <div class="alert alert-info" role="alert">
                                <p><strong>Quick Actions:</strong></p>
                                <button name="%(action_recruitment_job_order)d" type="action" string="View All Jobs" class="btn btn-primary"/>
                                <button name="%(action_recruitment_job_order)d" type="action" string="Active Jobs" class="btn btn-success" context="{'search_default_active_jobs': 1}"/>
                            </div>
                        </page>

                        <!-- Candidates Tab -->
                        <page string="👥 Candidates">
                            <group string="Candidate Statistics" col="4">
                                <field name="candidate_total"/>
                                <field name="candidate_new" decoration-info="candidate_new > 0"/>
                                <field name="candidate_interview" decoration-warning="candidate_interview > 0"/>
                                <field name="candidate_offered" decoration-success="candidate_offered > 0"/>
                            </group>
                            
                            <group string="AI Matching Results" col="3">
                                <field name="candidate_high_match" decoration-success="candidate_high_match > 0" string="High Match (80%+)"/>
                                <field name="candidate_good_match" decoration-warning="candidate_good_match > 0" string="Good Match (50-79%)"/>
                            </group>
                            
                            <div class="alert alert-info" role="alert">
                                <p><strong>Quick Actions:</strong></p>
                                <button name="%(action_recruitment_candidate)d" type="action" string="View All Candidates" class="btn btn-primary"/>
                                <button name="%(action_recruitment_candidate)d" type="action" string="Interview Stage" class="btn btn-warning" context="{'search_default_interview_stage': 1}"/>
                            </div>
                        </page>

                        <!-- Revenue Tab -->
                        <page string="💰 Revenue">
                            <group string="Revenue Analytics" col="4">
                                <field name="total_placements"/>
                                <field name="revenue_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="revenue_commission" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="revenue_avg_commission" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </group>
                            
                            <div class="alert alert-success" role="alert">
                                <h4>💵 Total Revenue: <field name="revenue_total" readonly="1" nolabel="1" widget="monetary" options="{'currency_field': 'currency_id'}"/></h4>
                                <p>From <field name="total_placements" readonly="1" nolabel="1"/> successful placements</p>
                            </div>
                            
                            <div class="alert alert-info" role="alert">
                                <p><strong>Quick Actions:</strong></p>
                                <button name="%(action_recruitment_placement)d" type="action" string="View All Placements" class="btn btn-primary"/>
                                <button name="%(action_recruitment_placement)d" type="action" string="Active Placements" class="btn btn-success" context="{'search_default_active_placements': 1}"/>
                            </div>
                        </page>

                        <!-- Clients Tab -->
                        <page string="🏢 Clients">
                            <group string="Client Overview" col="3">
                                <field name="total_clients"/>
                                <field name="active_clients" decoration-success="active_clients > 0"/>
                            </group>
                            
                            <div class="alert alert-info" role="alert">
                                <p><strong>Quick Actions:</strong></p>
                                <button name="%(action_recruitment_client)d" type="action" string="View All Clients" class="btn btn-primary"/>
                            </div>
                        </page>

                        <!-- Visa Processing Tab -->
                        <page string="🛂 Visa Processing">
                            <group string="Visa Status" col="3">
                                <field name="visa_in_progress" decoration-warning="visa_in_progress > 0"/>
                                <field name="visa_completed" decoration-success="visa_completed > 0"/>
                            </group>
                            
                            <div class="alert alert-info" role="alert">
                                <p><strong>Quick Actions:</strong></p>
                                <button name="%(action_uae_visa_processing)d" type="action" string="View All Visas" class="btn btn-primary"/>
                                <button name="%(action_uae_visa_processing)d" type="action" string="In Progress" class="btn btn-warning" context="{'search_default_in_progress': 1}"/>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_recruitment_dashboard" model="ir.actions.act_window">
        <field name="name">Recruitment Dashboard</field>
        <field name="res_model">recruitment.dashboard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_recruitment_dashboard_form"/>
        <field name="target">current</field>
        <field name="context">{'form_view_initial_mode': 'readonly', 'create': False, 'edit': False, 'delete': False}</field>
        <field name="limit">1</field>
    </record>

    <!-- Server Action to Open Dashboard (always loads first record) -->
    <record id="action_open_dashboard" model="ir.actions.server">
        <field name="name">Open Recruitment Dashboard</field>
        <field name="model_id" ref="model_recruitment_dashboard"/>
        <field name="state">code</field>
        <field name="code">
# Get or create singleton dashboard
dashboard = env['recruitment.dashboard'].search([], limit=1)
if not dashboard:
    dashboard = env['recruitment.dashboard'].create({'name': 'Dashboard'})

action = {
    'type': 'ir.actions.act_window',
    'name': 'Recruitment Dashboard',
    'res_model': 'recruitment.dashboard',
    'res_id': dashboard.id,
    'view_mode': 'form',
    'view_id': env.ref('uae_recruitment_mgmt.view_recruitment_dashboard_form').id,
    'target': 'current',
    'context': {'form_view_initial_mode': 'readonly'},
}
        </field>
    </record>

</odoo>